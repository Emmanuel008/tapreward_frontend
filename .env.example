# Leave empty in development — requests use /api/* via setupProxy.js → live server.
REACT_APP_API_URL=
REACT_APP_PROXY_TARGET=https://tap.jitihada.co.tz

# Production build:
# REACT_APP_API_URL=https://tap.jitihada.co.tz

# Optional: if npm start fails with allowedHosts error, uncomment:
# HOST=localhost

# For production on a different domain:
# REACT_APP_API_URL=http://tap.jitihada.co.tz
