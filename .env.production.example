# Production build — set ONE of these options:

# Option A: Frontend and API on different hosts (e.g. tapreward.* → tap.*)
REACT_APP_API_URL=http://tap.jitihada.co.tz

# Option B: Frontend and API on the same domain (nginx serves both)
# REACT_APP_USE_SAME_ORIGIN=true
# REACT_APP_API_URL=

# After HTTPS is enabled:
# REACT_APP_API_URL=https://tap.jitihada.co.tz
